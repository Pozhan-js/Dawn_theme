{{ 'section-my-feature.css' | asset_url | stylesheet_tag }}
<script src="{{ 'my-feature-accordion.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'theme-animation.js' | asset_url }}" defer="defer"></script>

<div
  id="MyFeature-{{ section.id }}"
  class="my-feature page-width"
  data-motion-section="my-feature">
  <div class="my-page-current">{{ request.page_type }}</div>

  <div class="my-feature__intro">
    <span
      class="my-feature__accent"
      data-motion="accent"
      aria-hidden="true"></span>
    {%- if section.settings.title != blank -%}
      <h1 class="my-feature__title" data-motion="title">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.subTitle != blank -%}
      <h2 class="my-feature__subTitle" data-motion="subtitle">{{ section.settings.subTitle }}</h2>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <my-feature-accordion
      class="my-feature__collapse"
      {% if section.settings.accordion_mode %}
      data-accordion-mode
      {% endif %}
      {% if section.settings.open_first_item %}
      data-open-first-item
      {% endif %}>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'accordion_item' -%}
            <div
              class="my-feature__collapse-item"
              data-motion="item"
              data-expanded="{% if block.settings.default_open or section.settings.open_first_item and forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}>
              <details id="MyFeatureAccordion-{{ block.id }}-{{ section.id }}">
                <summary class="my-feature__collapse-header" id="MyFeatureAccordionSummary-{{ block.id }}-{{ section.id }}">
                  <span class="my-feature__collapse-title">{{ block.settings.heading | escape }}</span>
                  <span class="my-feature__collapse-arrow" aria-hidden="true">
                    <svg viewBox="0 0 12 12" focusable="false">
                      <path
                        d="M4.5 2.5 8 6l-3.5 3.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round" />
                    </svg>
                  </span>
                </summary>
                <div class="my-feature__collapse-panel" data-motion-panel>
                  <div
                    class="my-feature__collapse-content rte"
                    id="MyFeatureAccordionContent-{{ block.id }}-{{ section.id }}"
                    role="region"
                    aria-labelledby="MyFeatureAccordionSummary-{{ block.id }}-{{ section.id }}">
                    {{ block.settings.content }}
                  </div>
                </div>
              </details>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </my-feature-accordion>
  {%- endif -%}

  {%- liquid
    assign feature_blog = blogs.news
    assign post_limit = section.settings.post_limit | default: 6
  -%}

  {%- if feature_blog != blank -%}
    <div class="my-feature__blog blog-page">
      <header class="blog-header">
        <h2 class="my-feature__blog-title">{{ feature_blog.title | escape }}</h2>
        {%- if feature_blog.description != blank -%}
          <p class="my-feature__blog-description">{{ feature_blog.description }}</p>
        {%- endif -%}
      </header>

      <div class="articles-grid">
        {%- if feature_blog.articles_count == 0 -%}
          <p class="blog-page__empty">
            博客「{{ feature_blog.title | escape }}」（{{ feature_blog.handle }}）当前在店面可读文章数为 0。
            <br>
            若后台显示「可见」仍为空，常见原因：<strong>发布时间设为未来时刻（定时发布）</strong>，需改为当前或过去时间并保存。
            <br>
            也可直接打开
            <a href="{{ feature_blog.url }}">{{ feature_blog.url }}</a>
            查看该博客列表页是否有文章。
          </p>
        {%- else -%}
          {%- for article in feature_blog.articles limit: post_limit -%}
            <article class="article-card">
              <!-- 文章特色图片 -->
              {% if article.image %}
                <div class="article-image">
                  <a href="{{ article.url }}">
                    <img
                      src="{{ article.image | image_url: width: 400, height: 250 }}"
                      alt="{{ article.image.alt | escape }}"
                      width="400"
                      height="250"
                      loading="lazy">
                  </a>
                </div>
              {% endif %}

              <!-- 文章内容 -->
              <div class="article-content">
                <h2>
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h2>

                <!-- 文章元信息 -->
                <div class="article-meta">
                  <time>{{ article.published_at | date: "%Y年%m月%d日" }}</time>
                  {% if article.author != blank %}
                    <span class="author">作者: {{ article.author }}</span>
                  {% endif %}
                  {% if article.tags.size > 0 %}
                    <div class="tags">
                      {% for tag in article.tags %}
                        <span class="tag">{{ tag }}</span>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>

                <!-- 文章摘要 -->
                <div class="article-excerpt">
                  {{ article.excerpt | default: article.content | strip_html | truncate: 150 }}
                </div>

                <a href="{{ article.url }}" class="read-more">阅读更多</a>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>


{% style %}
  .my-page-current {
    color: red;
    font-size: 2rem;
  }
{% endstyle %}

{% schema %}
  {
    "name": "底部区域展示横条",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "text",
        "id": "subTitle",
        "label": "副标题"
      },
      {
        "type": "header",
        "content": "折叠面板"
      },
      {
        "type": "checkbox",
        "id": "accordion_mode",
        "label": "手风琴模式（同时只展开一项）",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "open_first_item",
        "label": "默认展开第一项",
        "default": true
      },
      {
        "type": "header",
        "content": "博客文章列表（固定 news 博客）"
      },
      {
        "type": "range",
        "id": "post_limit",
        "min": 1,
        "max": 12,
        "step": 1,
        "default": 6,
        "label": "显示文章数量"
      }
    ],
    "blocks": [
      {
        "type": "accordion_item",
        "name": "折叠项",
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "标题",
            "default": "折叠面板"
          },
          {
            "type": "richtext",
            "id": "content",
            "label": "内容",
            "default": "<p>这里是折叠内容，可在主题编辑器中修改。</p>"
          },
          {
            "type": "checkbox",
            "id": "default_open",
            "label": "默认展开",
            "default": false
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "My Feature 1",
        "blocks": [
          {
            "type": "accordion_item",
            "settings": {
              "heading": "面板一",
              "content": "<p>这是第一个折叠面板的内容。</p>"
            }
          },
          {
            "type": "accordion_item",
            "settings": {
              "heading": "面板二",
              "content": "<p>这是第二个折叠面板的内容。</p>"
            }
          },
          {
            "type": "accordion_item",
            "settings": {
              "heading": "面板三",
              "content": "<p>这是第三个折叠面板的内容。</p>"
            }
          }
        ]
      }
    ],
    "limit": 2
  }
{% endschema %}