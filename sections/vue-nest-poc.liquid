{% render 'vue-nest-poc-vite-tag' %}

{%- liquid
  assign size_chart_metaobject = blank
  assign size_chart_metafield = blank

  if product != blank
    assign size_chart_metafield = product.metafields[section.settings.metafield_namespace][section.settings.metafield_key]
    assign size_chart_metaobject = size_chart_metafield.value
  endif

  if size_chart_metaobject == blank and section.settings.metaobject_handle != blank
    assign size_chart_metaobject = metaobjects[section.settings.metaobject_type][section.settings.metaobject_handle]
  endif
-%}

<style>
  [data-vue-nest-poc] table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
  }
  [data-vue-nest-poc] table th,
  [data-vue-nest-poc] table td {
    padding: 1.4rem 1.6rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  [data-vue-nest-poc] table thead th {
    background: rgba(var(--color-foreground), 0.04);
    font-weight: 600;
  }
  [data-vue-nest-poc] table tbody tr:last-child th,
  [data-vue-nest-poc] table tbody tr:last-child td {
    border-bottom: 0;
  }
</style>

<div class="vue-nest-poc-section color-{{ section.settings.color_scheme }}">
  <div class="vue-nest-poc-section__inner">
    <div
      data-vue-nest-poc
      data-api-url="{{ section.settings.api_url | escape }}"
      data-heading="{{ section.settings.heading | escape }}">
      <p>正在加载 Vue 组件...</p>
    </div>
    <script type="application/json" data-vue-nest-poc-source>
      {
        "page": {
          "id": {{ page.id | json }},
          "title": {{ page.title | json }},
          "handle": {{ page.handle | json }},
          "url": {{ page.url | json }}
        },
        "sizeChart": {
          "heading": {{ size_chart_metaobject.title.value | default: section.settings.size_heading | json }},
          "note": {{ size_chart_metaobject.note.value | default: section.settings.size_note | json }},
          "rowsRaw": {{ size_chart_metaobject.rows.value | json }},
          "metaobject": {
            "namespace": {{ section.settings.metafield_namespace | json }},
            "key": {{ section.settings.metafield_key | json }},
            "type": {{ size_chart_metaobject.system.type | json }},
            "handle": {{ size_chart_metaobject.system.handle | json }},
            "fallbackType": {{ section.settings.metaobject_type | json }},
            "fallbackHandle": {{ section.settings.metaobject_handle | json }},
            "loaded": {% if size_chart_metaobject != blank %}true{% else %}false{% endif %}
          },
          "columns": [
            {{ section.settings.size_label | json }},
            {{ section.settings.shoulder_label | json }},
            {{ section.settings.chest_label | json }},
            {{ section.settings.length_label | json }},
            {{ section.settings.sleeve_label | json }}
          ],
          "rows": [
            {%- for block in section.blocks -%}
              {
                "size": {{ block.settings.size | json }},
                "shoulder": {{ block.settings.shoulder | json }},
                "chest": {{ block.settings.chest | json }},
                "length": {{ block.settings.length | json }},
                "sleeve": {{ block.settings.sleeve | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }
      }
    </script>
  </div>
</div>

{% style %}
  [data-vue-nest-poc] .vue-nest-poc-size-chart__wrapper,
  [data-vue-nest-poc] .overflow-x-auto:has(table) {
    overflow-x: auto;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
    border-radius: 0.5rem;
  }

  [data-vue-nest-poc] .vue-nest-poc-size-chart__table,
  [data-vue-nest-poc] table {
    width: 100%;
    min-width: 58rem;
    border-collapse: collapse;
    text-align: center;
  }

  [data-vue-nest-poc] .vue-nest-poc-size-chart__table th,
  [data-vue-nest-poc] .vue-nest-poc-size-chart__table td,
  [data-vue-nest-poc] table th,
  [data-vue-nest-poc] table td {
    padding: 1.4rem 1.6rem;
    border-style: solid;
    border-width: 0;
    border-bottom-width: 0.1rem;
    border-bottom-color: rgba(var(--color-foreground), 0.12);
  }

  [data-vue-nest-poc] .vue-nest-poc-size-chart__table thead th,
  [data-vue-nest-poc] table thead th {
    background: rgba(var(--color-foreground), 0.04);
    font-weight: 600;
  }

  [data-vue-nest-poc] .vue-nest-poc-size-chart__table tbody tr:last-child th,
  [data-vue-nest-poc] .vue-nest-poc-size-chart__table tbody tr:last-child td,
  [data-vue-nest-poc] table tbody tr:last-child th,
  [data-vue-nest-poc] table tbody tr:last-child td {
    border-bottom-width: 0;
  }
{% endstyle %}

{% schema %}
  {
    "name": "Vue Nest POC",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "标题",
        "default": "Vue 已挂载到 Liquid 区块"
      },
      {
        "type": "text",
        "id": "api_url",
        "label": "Nest 接口地址",
        "default": "http://localhost:4000/api/vue-nest-poc"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "配色方案",
        "default": "scheme-1"
      },
      {
        "type": "text",
        "id": "metafield_namespace",
        "label": "商品 metafield namespace",
        "default": "custom"
      },
      {
        "type": "text",
        "id": "metafield_key",
        "label": "商品 metafield key",
        "default": "size_chart"
      },
      {
        "type": "text",
        "id": "metaobject_type",
        "label": "测试页兜底元对象类型",
        "default": "size_chart"
      },
      {
        "type": "text",
        "id": "metaobject_handle",
        "label": "测试页兜底元对象 handle",
        "default": "man_shot_on_table"
      },
      {
        "type": "text",
        "id": "size_heading",
        "label": "尺码表标题",
        "default": "Vue 渲染的尺码表"
      },
      {
        "type": "text",
        "id": "size_label",
        "label": "尺码列标题",
        "default": "尺码"
      },
      {
        "type": "text",
        "id": "shoulder_label",
        "label": "肩宽列标题",
        "default": "肩宽 (cm)"
      },
      {
        "type": "text",
        "id": "chest_label",
        "label": "胸围列标题",
        "default": "胸围 (cm)"
      },
      {
        "type": "text",
        "id": "length_label",
        "label": "衣长列标题",
        "default": "衣长 (cm)"
      },
      {
        "type": "text",
        "id": "sleeve_label",
        "label": "袖长列标题",
        "default": "袖长 (cm)"
      },
      {
        "type": "text",
        "id": "size_note",
        "label": "尺码表备注",
        "default": "这些尺码数据由 Liquid section blocks 输出，再交给 Vue 渲染。"
      }
    ],
    "blocks": [
      {
        "type": "size_row",
        "name": "尺码行",
        "settings": [
          {
            "type": "text",
            "id": "size",
            "label": "尺码",
            "default": "M"
          },
          {
            "type": "text",
            "id": "shoulder",
            "label": "肩宽",
            "default": "45"
          },
          {
            "type": "text",
            "id": "chest",
            "label": "胸围",
            "default": "104"
          },
          {
            "type": "text",
            "id": "length",
            "label": "衣长",
            "default": "68"
          },
          {
            "type": "text",
            "id": "sleeve",
            "label": "袖长",
            "default": "61"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Vue Nest POC",
        "blocks": [
          {
            "type": "size_row"
          },
          {
            "type": "size_row"
          },
          {
            "type": "size_row"
          }
        ]
      }
    ]
  }
{% endschema %}
